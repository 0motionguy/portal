{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/install",
      "headers": [
        { "key": "content-type", "value": "text/plain; charset=utf-8" },
        { "key": "cache-control", "value": "public, max-age=60, must-revalidate" }
      ]
    },
    {
      "source": "/install.ps1",
      "headers": [
        { "key": "content-type", "value": "text/plain; charset=utf-8" },
        { "key": "cache-control", "value": "public, max-age=60, must-revalidate" }
      ]
    },
    {
      "source": "/directory.json",
      "headers": [
        { "key": "content-type", "value": "application/json; charset=utf-8" },
        { "key": "cache-control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "content-type", "value": "application/manifest+json" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "x-content-type-options", "value": "nosniff" },
        { "key": "strict-transport-security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "x-frame-options", "value": "DENY" },
        { "key": "referrer-policy", "value": "strict-origin-when-cross-origin" },
        { "key": "permissions-policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "content-security-policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'" }
      ]
    }
  ]
}
