{
  "name": "@visitportal/mcp-adapter",
  "license": "Apache-2.0",
  "version": "0.1.6",
  "private": false,
  "description": "Wrap an MCP stdio server as a Portal. Minimal client, manifest translation, and local HTTP bridge.",
  "type": "module",
  "bin": {
    "visitportal-mcp-adapter": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@visitportal/provider": "workspace:^0.1.6",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "vitest": "^2.1.8"
  }
}
