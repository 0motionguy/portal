{
  "name": "@visitportal/spec",
  "license": "Apache-2.0",
  "version": "0.1.4",
  "private": false,
  "description": "Portal spec artifacts — JSON Schema + conformance test vectors + runner.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": "./manifest.schema.json",
    "./vectors": "./conformance/vectors.json",
    "./runner": {
      "types": "./dist/conformance/runner.d.ts",
      "default": "./dist/conformance/runner.js"
    },
    "./lean-validator": {
      "types": "./dist/conformance/lean-validator.d.ts",
      "default": "./dist/conformance/lean-validator.js"
    }
  },
  "files": [
    "dist/",
    "manifest.schema.json",
    "conformance/vectors.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx conformance/self-test.ts",
    "mock": "tsx conformance/mock-server.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2"
  }
}
