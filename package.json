{
  "name": "visitportal-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Portal — the drop-in visit layer for LLM clients. Monorepo root.",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "biome check .",
    "bench": "tsx scripts/bench.ts",
    "conformance": "tsx scripts/conformance.ts",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@visitportal/spec": "workspace:*",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3"
  }
}
